{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "electron-vite/node"],
    "outDir": "out/main"
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
